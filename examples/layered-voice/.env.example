# ── Layered Voice Agents example ─────────────────────────────────────────────
# The three agents (front / worker / addressing-monitor) run server-side and
# talk to a model provider through glove-core's createAdapter.
#
# Default provider is OpenRouter, using affordable open models. Set your key:
OPENROUTER_API_KEY=sk-or-...

# ── Optional overrides ───────────────────────────────────────────────────────
# Provider for all three agents. Default: openrouter.
# VOICE_PROVIDER=openrouter

# Default open models on OpenRouter:
#   front   = z-ai/glm-5.2          (conversational, spoken persona)
#   monitor = xiaomi/mimo-v2.5-pro  (reasons about who each line is addressed to)
#   worker  = minimax/minimax-m2.5  (heavy, tool-driven work over the shop DB)
# Override any role independently:
# FRONT_MODEL=z-ai/glm-5.2
# MONITOR_MODEL=xiaomi/mimo-v2.5-pro
# WORKER_MODEL=minimax/minimax-m2.5

# To use Anthropic instead:
#   VOICE_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=sk-ant-...
# (defaults to claude-haiku-4-5 for front/monitor and claude-sonnet-4 for worker)

# ── Full-duplex voice (ElevenLabs) ───────────────────────────────────────────
# Required to enable the mic + spoken output. Stays server-side — the browser
# only ever receives short-lived tokens from /api/voice/*-token routes.
ELEVENLABS_API_KEY=sk_...

# The ElevenLabs voice used for Nova (client-side, so it needs NEXT_PUBLIC_).
# Defaults to a stock voice if unset.
# NEXT_PUBLIC_ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ── Voice latency metrics ────────────────────────────────────────────────────
# Every turn's timings (time-to-first-audio, STT latency, monitor/worker/relay
# latency, barge-ins) are appended to a local JSONL file for offline analysis.
# Default: ./voice-metrics.jsonl (relative to the app's working dir).
# VOICE_METRICS_FILE=./voice-metrics.jsonl
