# ── Layered Voice Agents example ─────────────────────────────────────────────
# The two agents (front / worker) run server-side and talk to a model provider
# through glove-core's createAdapter.
#
# Default provider is OpenRouter, using affordable open models. Set your key:
OPENROUTER_API_KEY=sk-or-...

# ── Optional overrides ───────────────────────────────────────────────────────
# Provider for both agents. Default: openrouter.
# VOICE_PROVIDER=openrouter

# Default open models on OpenRouter:
#   front  = openai/gpt-oss-120b   (spoken persona; its <speech> spans stream into TTS)
#   worker = minimax/minimax-m2.5  (heavy lifting + a ton of tool calls over the DB)
# Override any role independently:
# FRONT_MODEL=openai/gpt-oss-120b
# WORKER_MODEL=minimax/minimax-m2.5

# How hard the FRONT model may think before speaking — silent reasoning is
# dead air on a voice line. Options:
#   low (default)  reasoning: { effort: "low" } — widely supported
#   budget:<n>     reasoning: { max_tokens: n } — HARD thinking cap; use this
#                  for models that ignore effort (e.g. qwen3 *-thinking
#                  variants: try budget:256)
#   off            reasoning: { enabled: false } — some providers reject this
#   none           send no reasoning param (provider default)
# FRONT_REASONING=budget:256

# OpenRouter provider routing for the front model. WHO serves the model
# matters more for latency than the model itself — measured on gpt-oss-120b:
# 979ms TTFT on default routing vs 160ms via sort=throughput (Cerebras), a 6x
# difference on identical weights. DEFAULT: throughput (on OpenRouter).
# Options: throughput | latency | price | off.
# FRONT_PROVIDER_SORT=off

# To use Anthropic instead:
#   VOICE_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=sk-ant-...
# (defaults to claude-haiku-4-5 for front and claude-sonnet-4 for worker)

# ── Full-duplex voice (ElevenLabs) ───────────────────────────────────────────
# Required to enable the mic + spoken output. Stays server-side — the browser
# only ever receives short-lived tokens from /api/voice/*-token routes.
ELEVENLABS_API_KEY=sk_...

# The ElevenLabs voice used for Nova (client-side, so it needs NEXT_PUBLIC_).
# Defaults to a stock voice if unset.
# NEXT_PUBLIC_ELEVENLABS_VOICE_ID=uYXf8XasLslADfZ2MB4u

# TTS model. Default eleven_flash_v2_5 — ElevenLabs' fastest (~75ms model
# latency). Set eleven_turbo_v2_5 for slightly richer delivery at ~2-3x the
# first-audio latency.
# NEXT_PUBLIC_TTS_MODEL=eleven_flash_v2_5

# End-of-speech silence window in ms (default 450). THE floor of send latency:
# nothing starts until this much trailing silence has passed. Endpointing is
# two-tier: a partial that reads FINISHED (ends .?!) sends at this boundary; a
# mid-thought partial gets an extra hold (below) so pauses don't cut you off.
# NEXT_PUBLIC_VAD_SILENCE_MS=450
# Extra hold beyond the VAD boundary when the transcript sounds unfinished
# (default 900). Resuming speech cancels it — same utterance keeps growing.
# NEXT_PUBLIC_ENDPOINT_HOLD_MS=900
# Medium hold for period-terminated partials (default 600). Scribe punctuates
# its partials, so a trailing "." is only weak evidence the speaker finished;
# only "?"/"!" endings take the fast no-hold path.
# NEXT_PUBLIC_ENDPOINT_HOLD_SOFT_MS=600

# ── Persistence ──────────────────────────────────────────────────────────────
# The mesh itself needs no database (in-process bus). What persists is each
# agent's store — transcripts + the inbox, where mesh state lives. Default is
# in-memory (gone on restart). Set "pglite" to persist via embedded Postgres
# (@electric-sql/pglite, pure WASM — no native bindings):
# VOICE_PERSIST=pglite
# Data directory for pglite mode (default: ./voice-agents-db):
# VOICE_DB_DIR=./voice-agents-db
# Clear everything: the "Clear data" button in the console, or `pnpm clear`
# (server stopped), or delete the data directory.

# ── Voice latency metrics ────────────────────────────────────────────────────
# Every turn's timings (time-to-first-audio, STT latency, worker/relay latency,
# barge-ins) are appended to a local JSONL file for offline analysis.
# Default: ./voice-metrics.jsonl (relative to the app's working dir).
# VOICE_METRICS_FILE=./voice-metrics.jsonl

# Voice activity detection. Default is the fast zero-cost energy VAD.
# Set to "silero" for the neural VAD (better speech-vs-noise discrimination in
# loud rooms, but heavier — ONNX per audio frame can add end-of-speech latency).
# NEXT_PUBLIC_VOICE_VAD=silero

# Hold when the speaker is spelling out an id letter-by-letter (default 2000).
# Detected by the transcript ending in a 1-2 character token; overrides the
# punctuation tiers so "K... E... S... 0-0-7" stays one utterance.
# NEXT_PUBLIC_SPELL_HOLD_MS=2000
