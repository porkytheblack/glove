# ── Layered Voice Agents example ─────────────────────────────────────────────
# The three agents (front / worker / addressing-monitor) run server-side and
# talk to a model provider through glove-core's createAdapter.
#
# Default provider is Anthropic. Set your key:
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional overrides ───────────────────────────────────────────────────────
# Provider for all three agents (anthropic | openai | openrouter | gemini | ...).
# Whatever you pick, set that provider's API key env var (see the glove-core
# providers table). Example: VOICE_PROVIDER=openrouter + OPENROUTER_API_KEY=...
# VOICE_PROVIDER=anthropic

# The front agent and the monitor are meant to be small/fast; the worker is the
# heavy capability layer. Override the model per role if you like.
# FRONT_MODEL=claude-haiku-4-5-20251001
# MONITOR_MODEL=claude-haiku-4-5-20251001
# WORKER_MODEL=claude-sonnet-4-20250514
