# Anthropic API key for the model
ANTHROPIC_API_KEY=sk-ant-...
# Optional — defaults to claude-sonnet-4-5
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ─── Notion: MCP-spec OAuth (recommended — `pnpm mcp:notion-mcp-auth`) ───────
# Runs against https://mcp.notion.com/mcp using the MCP authorization spec
# (Dynamic Client Registration + PKCE). No client_id/secret needed — the
# server registers the client dynamically. Same path Claude Code uses.
#
# Optional — port the auth CLI listens on for the OAuth callback.
# NOTION_MCP_OAUTH_PORT=53683
# Optional — defaults to http://localhost:${NOTION_MCP_OAUTH_PORT}/callback
# NOTION_MCP_OAUTH_REDIRECT_URI=http://localhost:53683/callback

# Optional — defaults to https://mcp.notion.com/mcp. Override if you want
# the agent to hit a different MCP endpoint (e.g. http://localhost:3030/mcp
# from `pnpm mcp:notion-server` for the self-hosted path).
# NOTION_MCP_URL=https://mcp.notion.com/mcp

# ─── Notion: api.notion.com OAuth (alternative — `pnpm mcp:notion-auth`) ─────
# Used with the self-hosted @notionhq/notion-mcp-server path. Public
# integration credentials from https://www.notion.so/profile/integrations.
# Add http://localhost:53682/callback as the redirect URI on the integration.
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
# Optional — defaults to 53682
# NOTION_OAUTH_PORT=53682
# Optional — defaults to http://localhost:${NOTION_OAUTH_PORT}/callback
# NOTION_OAUTH_REDIRECT_URI=http://localhost:53682/callback

# ─── Notion: pre-existing token (optional override) ──────────────────────────
# If set, the agent uses this directly and skips both OAuth paths. Useful for
# internal integration tokens (ntn_…) when you're running notion-mcp-server
# yourself. Leave blank to use the OAuth flows.
NOTION_TOKEN=

# Optional — port `pnpm mcp:notion-server` binds on for self-hosted setups.
# Must match the port in NOTION_MCP_URL.
# NOTION_MCP_PORT=3030

# ─── Linear MCP (only used by the multi-MCP discovery CLI) ───────────────────
LINEAR_TOKEN=
