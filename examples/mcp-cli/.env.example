# Anthropic API key for the model
ANTHROPIC_API_KEY=sk-ant-...
# Optional — defaults to claude-sonnet-4-5
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ─── Notion MCP ──────────────────────────────────────────────────────────────
# Bearer token used for `Authorization: Bearer <NOTION_TOKEN>` against the
# Notion MCP server. See README.md for which token to use depending on
# whether you're hitting the hosted server or running notion-mcp-server
# locally behind an HTTP proxy.
NOTION_TOKEN=

# Optional — defaults to https://mcp.notion.com/mcp (Notion's hosted server).
# Override if you're running the official notion-mcp-server behind a local
# HTTP proxy, e.g. http://localhost:3030/mcp
# NOTION_MCP_URL=https://mcp.notion.com/mcp

# ─── Linear MCP (only used by the multi-MCP discovery CLI) ───────────────────
LINEAR_TOKEN=
