# Anthropic API key for the model
ANTHROPIC_API_KEY=sk-ant-...
# Optional — defaults to claude-sonnet-4-5
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ─── Notion: OAuth (recommended path — `pnpm mcp:notion-auth`) ───────────────
# Public integration credentials from https://www.notion.so/profile/integrations
# After creating a Public integration, add its redirect URI as
# http://localhost:53682/callback (or whatever NOTION_OAUTH_PORT you choose).
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
# Optional — defaults to 53682
# NOTION_OAUTH_PORT=53682
# Optional — defaults to http://localhost:${NOTION_OAUTH_PORT}/callback. Must
# match the redirect URI configured on your Notion integration.
# NOTION_OAUTH_REDIRECT_URI=http://localhost:53682/callback

# ─── Notion: pre-existing token (optional override) ──────────────────────────
# If set, the agent uses this directly and ignores .notion-token.json. Useful
# for internal integration tokens (ntn_…) when you're running a self-hosted
# notion-mcp-server behind an HTTP proxy. Leave blank to use the OAuth flow.
NOTION_TOKEN=

# Optional — defaults to http://localhost:3030/mcp, which is what
# `pnpm mcp:notion-server` listens on. Override only if you have an
# MCP-flavored token for https://mcp.notion.com/mcp (different OAuth audience
# than api.notion.com — see README).
# NOTION_MCP_URL=http://localhost:3030/mcp

# Optional — port `pnpm mcp:notion-server` binds on. Must match NOTION_MCP_URL.
# NOTION_MCP_PORT=3030

# ─── Linear MCP (only used by the multi-MCP discovery CLI) ───────────────────
LINEAR_TOKEN=
