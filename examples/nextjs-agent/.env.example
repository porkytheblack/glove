# API key for your provider (set the one matching your chat route config)
OPENAI_API_KEY=sk-...

# For other providers, use their respective env var:
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
# GEMINI_API_KEY=...

# Optional — enable glove-monitor telemetry. Server-only.
# GLOVE_MONITOR_URL=http://localhost:4500
# GLOVE_MONITOR_REG_TOKEN=gmrt_demo_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
