OPENROUTER_API_KEY=your-key-here

# Telemetry — populated automatically by `pnpm monitor:bootstrap`. The browser
# bundle never sees these; they're only read by the server-side relay handler
# at /api/glove-monitor/ingest. Leave unset to disable telemetry entirely.
# GLOVE_MONITOR_URL=http://127.0.0.1:4500
# GLOVE_MONITOR_REG_TOKEN=gmrt_coffee-demo_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
