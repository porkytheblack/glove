OPENROUTER_API_KEY=your-key-here

# Optional — enable glove-monitor telemetry. The browser bundle never sees
# these; they're only read by the server-side relay handler at
# /api/glove-monitor/ingest. Leave unset to disable telemetry.
# GLOVE_MONITOR_URL=http://localhost:4500
# GLOVE_MONITOR_REG_TOKEN=gmrt_demo_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
