{
  "name": "glove-scratchpad-bench",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Agentic A/B benchmark: 10 mocked MCP servers, real models via OpenRouter, with vs without glove-scratchpad.",
  "scripts": {
    "bench": "tsx --env-file=../../.env src/run.ts",
    "frame-bench": "tsx --env-file-if-exists=../../.env src/frame-bench.ts",
    "frame-choice-bench": "tsx --env-file-if-exists=../../.env src/frame-choice-bench.ts",
    "frame-figures": "tsx src/frame-figures.ts",
    "frame-selfcheck": "tsx src/frame-selfcheck.ts",
    "exfil-bench": "tsx --env-file-if-exists=../../.env src/exfil-bench.ts",
    "exfil-selfcheck": "tsx src/exfil/selfcheck.ts",
    "exfil-figures": "tsx src/exfil-figures.ts",
    "selfcheck": "tsx src/selfcheck.ts",
    "probe:lisp": "tsx src/probe-lisp.ts",
    "probe:js": "tsx src/probe-js.ts",
    "probe:py": "tsx src/probe-py.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "glove-core": "workspace:*",
    "glove-egress": "workspace:*",
    "glove-js": "workspace:*",
    "glove-lisp": "workspace:*",
    "glove-python": "workspace:*",
    "glove-mcp": "workspace:*",
    "glove-scratchpad": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
