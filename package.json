{
  "name": "glove-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter glove-core build && pnpm --filter glove-sqlite build && pnpm --filter glove-mcp build && pnpm --filter glove-react build && pnpm --filter glove-next build && pnpm --filter glove-voice build && pnpm --filter glovebox build && pnpm --filter glovebox-kit build && pnpm --filter glovebox-client build",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "weather:agent": "tsx examples/weather-agent/index.tsx",
    "coding:agent": "tsx examples/coding-agent/index.tsx",
    "coding:server": "tsx examples/coding-agent/server.ts",
    "coding:client": "pnpm --filter glove-coding-agent-client dev",
    "mcp:build": "pnpm --filter glove-core exec tsup --no-dts --silent && pnpm --filter glove-mcp exec tsup --no-dts --silent",
    "mcp:cli": "pnpm mcp:build && tsx examples/mcp-cli/index.ts",
    "mcp:notion": "pnpm mcp:build && tsx examples/mcp-cli/notion-agent.ts",
    "mcp:notion-auth": "pnpm mcp:build && tsx examples/mcp-cli/notion-auth.ts",
    "mcp:notion-mcp-auth": "pnpm mcp:build && tsx examples/mcp-cli/notion-mcp-auth.ts",
    "mcp:notion-server": "pnpm mcp:build && tsx examples/mcp-cli/notion-server.ts",
    "mcp:notion-status": "pnpm mcp:build && tsx examples/mcp-cli/notion-status.ts",
    "mcp:gmail": "pnpm mcp:build && tsx examples/mcp-cli/gmail-agent.ts",
    "mcp:gmail-auth": "pnpm mcp:build && tsx examples/mcp-cli/gmail-mcp-auth.ts"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
