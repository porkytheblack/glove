{
  "name": "glove-scratchpad",
  "version": "0.1.0",
  "description": "The Scratchpad Computer for Glove — context-efficient multi-agent workflows via handles + deterministic SQL transforms over a durable store. Postgres-dialect manipulation surface, store-and-truncate result containment, serializable scratchpad. Bring-your-own backend.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/porkytheblack/glove.git",
    "directory": "packages/glove-scratchpad"
  },
  "homepage": "https://github.com/porkytheblack/glove",
  "bugs": "https://github.com/porkytheblack/glove/issues",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    },
    "./pglite": {
      "types": "./dist/backends/pglite.d.ts",
      "import": "./dist/backends/pglite.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx tests/*.test.ts"
  },
  "dependencies": {
    "glove-core": "workspace:*",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@electric-sql/pglite": "^0.5.0"
  },
  "peerDependenciesMeta": {
    "@electric-sql/pglite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@types/node": "^25.2.3",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
