{
  "name": "glove-scratchpad",
  "version": "0.3.0",
  "description": "A database emulator for LLM tool use — expose an agent's capabilities as a relational database it queries with one execute_sql tool. Resources become tables, WHERE pushes arguments down, information_schema is discovery, transactions stage outbound effects, and every statement is parsed before any tool runs. Uses glove-sql (a zero-dependency pure-JS Postgres-subset engine) as the default backend; PGlite optional.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/porkytheblack/glove.git",
    "directory": "packages/glove-scratchpad"
  },
  "homepage": "https://github.com/porkytheblack/glove",
  "bugs": "https://github.com/porkytheblack/glove/issues",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js"
    },
    "./memory": {
      "types": "./dist/backends/memory.d.ts",
      "import": "./dist/backends/memory.js"
    },
    "./pglite": {
      "types": "./dist/backends/pglite.d.ts",
      "import": "./dist/backends/pglite.js"
    },
    "./mcp": {
      "types": "./dist/db/mcp.d.ts",
      "import": "./dist/db/mcp.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx tests/*.test.ts"
  },
  "dependencies": {
    "glove-core": "workspace:*",
    "glove-sql": "workspace:*",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@electric-sql/pglite": "^0.5.0",
    "glove-mcp": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@electric-sql/pglite": {
      "optional": true
    },
    "glove-mcp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@types/node": "^25.2.3",
    "glove-mcp": "workspace:*",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
