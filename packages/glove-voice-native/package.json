{
  "name": "glove-voice-native",
  "version": "0.1.0",
  "description": "React Native / Expo audio backends for the Glove voice pipeline — on-device mic capture, PCM playback, and Silero VAD",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./silero-vad": {
      "types": "./dist/silero-vad.d.ts",
      "import": "./dist/silero-vad.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "expo",
    "voice",
    "vad",
    "stt",
    "tts",
    "glove"
  ],
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "eventemitter3": "^5.0.4",
    "glove-voice": "workspace:*"
  },
  "peerDependencies": {
    "expo-file-system": "*",
    "onnxruntime-react-native": ">=1.22.0",
    "react-native-audio-api": ">=0.13.0"
  },
  "peerDependenciesMeta": {
    "expo-file-system": {
      "optional": true
    },
    "onnxruntime-react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "onnxruntime-react-native": "^1.24.3",
    "react-native-audio-api": "^0.13.2",
    "typescript": "^5.9.3"
  }
}
