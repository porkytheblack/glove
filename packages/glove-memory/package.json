{
  "name": "glove-memory",
  "version": "0.6.0",
  "description": "Memory layer for the Glove agent framework — entity, episodic, resources, and context primitives with bring-your-own storage.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/porkytheblack/glove.git",
    "directory": "packages/glove-memory"
  },
  "homepage": "https://github.com/porkytheblack/glove",
  "bugs": "https://github.com/porkytheblack/glove/issues",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./entity": {
      "types": "./dist/entity/index.d.ts",
      "import": "./dist/entity/index.js"
    },
    "./episodic": {
      "types": "./dist/episodic/index.d.ts",
      "import": "./dist/episodic/index.js"
    },
    "./resources": {
      "types": "./dist/resources/index.d.ts",
      "import": "./dist/resources/index.js"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "import": "./dist/context/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    },
    "./in-memory": {
      "types": "./dist/in-memory/index.d.ts",
      "import": "./dist/in-memory/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx tests/*.test.ts"
  },
  "dependencies": {
    "glove-core": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
