{
  "name": "glove-voice-s2s",
  "version": "0.1.0",
  "description": "Speech-to-speech (realtime voice model) adapters for the Glove agent framework",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "voice",
    "speech-to-speech",
    "realtime",
    "webrtc",
    "agent"
  ],
  "dependencies": {
    "eventemitter3": "^5.0.4"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  }
}
